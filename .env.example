# ═══════════════════════════════════════════════════════════════════════════
# NSE Trading Platform — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── Fyers Broker Credentials ──────────────────────────────────────────────
FYERS_APP_ID=XXXXXXXX-100
FYERS_SECRET_KEY=your_secret_key_here
FYERS_REDIRECT_URI=https://127.0.0.1
FYERS_ACCESS_TOKEN=
FYERS_PIN=1234

# ── Capital & Risk ────────────────────────────────────────────────────────
TOTAL_CAPITAL=750000
RISK_PER_TRADE_PCT=0.5
MAX_CONCURRENT_POSITIONS=3
DAILY_LOSS_LIMIT_PCT=2.0
PER_STRATEGY_DAILY_LOSS=6000

# ── Trading Hours (IST) ──────────────────────────────────────────────────
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
PRE_MARKET_BUFFER_MIN=10
ENTRY_CUTOFF_IST=14:45
FLATTEN_TIME_IST=15:22
NO_TRADE_FIRST_MIN=3

# ── ORB + VWAP Strategy ──────────────────────────────────────────────────
ORB_PERIOD_MINUTES=15
ORB_BREAKOUT_BUFFER_PCT=0.05
VWAP_BAND_STD_MULTIPLIER=1.5
ORB_STOPLOSS_MODE=ORB_OPPOSITE
ORB_TARGET_RR=2.0
ORB_TRAIL_AFTER_RR=1.0
ORB_TRAIL_PCT=0.3

# ── Supply/Demand Zone Strategy ──────────────────────────────────────────
SD_LOOKBACK_DAYS=60
SD_MIN_ZONE_STRENGTH=2.0
SD_ZONE_FRESHNESS_DAYS=20
SD_RISK_REWARD_MIN=2.0
SD_MAX_ZONE_WIDTH_PCT=3.0

# ── Scanner ───────────────────────────────────────────────────────────────
SCAN_UNIVERSE=NIFTY50
SCAN_TOP_N=10

# ── Execution ─────────────────────────────────────────────────────────────
SLIPPAGE_PCT=0.05
PASSIVE_TIMEOUT_MS=3000
ORDER_RETRY_MAX=3
ORDER_RETRY_DELAY_SEC=2.0

# ── Brokerage / Cost Model ───────────────────────────────────────────────
BROKERAGE_FLAT_PER_ORDER=20
BROKERAGE_INTRADAY_PCT=0.03
STT_SELL_INTRADAY_PCT=0.025
EXCHANGE_TXN_PCT=0.00345
SEBI_TURNOVER_PCT=0.0001
GST_PCT=18.0
STAMP_DUTY_BUY_PCT=0.003
IPFT_PCT=0.0001

# ── Backtest ──────────────────────────────────────────────────────────────
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2025-01-01
BACKTEST_INITIAL_CAPITAL=750000

# ── Claude LLM (Phase 4) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3
LLM_ENABLED=false

# ── Dashboard ─────────────────────────────────────────────────────────────
DASHBOARD_PORT=8501
DASHBOARD_REFRESH_SEC=5

# ── Engine / API ──────────────────────────────────────────────────────────
ENGINE_API_PORT=8100
ENGINE_API_TOKEN=changeme
ENGINE_TICK_INTERVAL_SEC=60

# ── Database ──────────────────────────────────────────────────────────────
DB_NAME=trade.db
DEFAULT_USER_ID=default_user

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=storage/logs

# ── Telegram (Optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=