# ═══════════════════════════════════════════════════════════════════════════
# NSE Trading Platform — Git Ignore Rules
# ═══════════════════════════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────────────────────────
.env
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual Environment ──────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Database (don't commit live DB, but keep schema) ──────────────────────
storage/*.db
storage/*.db-wal
storage/*.db-shm

# ── Logs ──────────────────────────────────────────────────────────────────
storage/logs/*.jsonl
storage/logs/*.log

# ── Backtest Reports (can be large) ──────────────────────────────────────
backtest/reports/*.html
backtest/reports/*.csv
backtest/reports/*.json

# ── OS Files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter (if used for analysis) ───────────────────────────────────────
.ipynb_checkpoints/

# ── Docker ────────────────────────────────────────────────────────────────
*.log

# ── Fyers Token Cache ────────────────────────────────────────────────────
fyers_token.json
access_token.txt
storage/fyers_token.json
storage/broker_token.json